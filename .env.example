# --- K-LabDoc 서버 환경변수 예시 ---
# Railway > Variables 에 아래 값을 설정하세요.

# JWT 서명 키 (반드시 임의의 긴 문자열로 교체)
JWT_SECRET=change-this-to-a-long-random-string

# 토큰 유효기간 (예: 8h, 12h, 1d)
TOKEN_TTL=8h

# 최초 시드 사용자 기본 PIN (배포 후 반드시 변경)
DEFAULT_PIN=0000

# PostgreSQL 사용 시 (Railway Postgres 플러그인 추가하면 자동 주입됨)
# DATABASE_URL=postgresql://user:pass@host:port/dbname
# PGSSL=disable   # 로컬 비-SSL Postgres 사용 시에만

# 포트 (Railway가 자동 주입, 로컬은 3000 기본)
# PORT=3000
